# ─────────────────────────────────────────────────────────────
# ReadRoom environment
#
# The app runs with ZERO of these set (local demo mode: file-backed
# storage, dev-auth, and a labelled deterministic analysis engine).
# Add each group to switch that integration from fallback to production.
# ─────────────────────────────────────────────────────────────

# Public base URL (used for share links, OG tags). Defaults to http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Clerk auth ──────────────────────────────────────────────
# Present both keys to switch from local dev-auth to real Clerk sign-in.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: enables the /api/webhooks/clerk endpoint (user create/update/delete sync)
CLERK_WEBHOOK_SECRET=

# ── Database (Supabase Postgres) ────────────────────────────
# Present to switch from the file-backed store to Postgres via Drizzle.
DATABASE_URL=

# ── Supabase Storage (uploaded screenshots) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (live analysis) ───────────────────────────────
# Present to switch from the local demo engine to live Claude calls.
ANTHROPIC_API_KEY=
# Configurable, vision-capable model id. Documented default: claude-sonnet-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Upstash Redis (optional rate limiting) ──────────────────
# If absent, authenticated usage limits fall back to the database/file store.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
